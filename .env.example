# Backend
NODE_ENV=development
PORT=3001

# PostgreSQL/Supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autenix
DATABASE_SSL=false
SUPABASE_URL=https://project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=autenix-assets
UPLOAD_MAX_IMAGE_MB=3

# Security
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
MESA_SESSION_TTL_HOURS=12
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
TRUST_PROXY=false
PUBLIC_APP_URL=http://localhost:5173

# Initial admin bootstrap.
# Generate a bcrypt hash and never place the plain password here.
ADMIN_LOGIN=admin
ADMIN_PASSWORD_HASH=$2b$12$replace_with_a_real_bcrypt_hash

# Frontend
VITE_API_URL=http://localhost:3001
