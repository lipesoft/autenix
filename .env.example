# Backend
NODE_ENV=development
PORT=3001

# PostgreSQL/Supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autenix
MIGRATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autenix
RLS_DATABASE_URL=postgresql://autenix_backend:password@localhost:5432/autenix
DATABASE_SSL=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=60000
SUPABASE_URL=https://project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=autenix-assets
UPLOAD_MAX_IMAGE_MB=3

# Security
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
MESA_SESSION_TTL_HOURS=12
RATE_LIMIT_PUBLIC_READ_MAX=600
RATE_LIMIT_TABLE_READ_MAX=240
RATE_LIMIT_TABLE_ACTION_MAX=40
RATE_LIMIT_RESERVATION_CREATE_MAX=20
RATE_LIMIT_RESERVATION_READ_MAX=180
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
TRUST_PROXY=false
PUBLIC_APP_URL=http://localhost:5173

# Initial admin bootstrap.
# Generate a bcrypt hash and never place the plain password here.
ADMIN_LOGIN=admin
ADMIN_PASSWORD_HASH=$2b$12$replace_with_a_real_bcrypt_hash

# Frontend
VITE_API_URL=http://localhost:3001
